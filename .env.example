# Petrochamp Configuration File

# API Configuration
API_BASE_URL=http://localhost/petrochamp-sistema/backend/api
API_TIMEOUT=30

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=base_academica_petrochamp
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=86400

# File Upload Configuration
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,csv,json,xml

# Payment Configuration
PAYMENT_CURRENCY=AOA
PAYMENT_AUTHOR_PERCENTAGE=70
PAYMENT_PLATFORM_PERCENTAGE=30

# Security Configuration
BCRYPT_COST=12
CORS_ALLOWED_ORIGINS=*
SESSION_TIMEOUT=3600

# Email Configuration (Future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=kialamanuel001@gmail.com
SMTP_PASSWORD=CheLseaFCB@1
SMTP_FROM=kialamanuel001@gmail.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/petrochamp.log

# Environment
ENVIRONMENT=development
DEBUG_MODE=true
